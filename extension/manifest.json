{
    "manifest_version": 3,
    "name": "Real Review Checker",
    "version": "1.0",
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "host_permissions": [
        "https://*/*",
        "http://localhost:5000/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.amazon.com/*",
                "*://*.amazon.in/*",
                "*://*.flipkart.com/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}